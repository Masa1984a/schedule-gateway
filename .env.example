# ===== schedule-gateway 環境変数 =====
# このファイルを .env.local にコピーして実値を設定する（.env.local はコミット禁止）。
# 本番値は Vercel の Environment Variables に登録する。

# Anthropic Console で発行した API キー（Managed Agents 呼び出し）
ANTHROPIC_API_KEY=sk-ant-...

# 既存 Agent / Environment の ID（schedule/managed-agent/agent-ids.json より）
AGENT_ID=agent_01XtE3W37NR3jjDRSbTFc8eh
ENVIRONMENT_ID=env_01H8NkXMX3wsZCXx1hM9w1Hn

# 予定データ側の Neon 接続文字列（ドメインDB: speaking_events / travel_routes）。
# bootstrap でサンドボックスの ~/.neonrc に DATABASE_URL として注入され、スキルが使う。
# 注意: シングルクオート(')を含む値は bootstrap が壊れるため不可。
DATABASE_URL=postgresql://user:password@host/scheduledb?sslmode=require

# セッション台帳側の Neon 接続文字列（gateway_sessions 専用。予定DBとは別インスタンス）。
# ゲートウェイ自身が user_key↔session_id を保存・再利用するためだけに使う。
SESSION_DATABASE_URL=postgresql://user:password@host/sessiondb?sslmode=require

# 自分専用の認証トークン。長いランダム文字列を生成して設定する。
#   生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_TOKEN=replace-with-a-long-random-secret

# （任意）ベータヘッダの上書き。通常は SDK が自動付与するため未設定で良い。
# ANTHROPIC_BETA=managed-agents-2026-04-01
